{
  "name": "media-admin",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "web:dev": "pnpm --filter web dev",
    "web:lint": "pnpm --filter web lint",
    "web:preview": "pnpm --filter web preview",
    "web:build": "pnpm --filter web build",
    "server:dev": "cargo run -p media-admin-server",
    "server:dev:cuda": "cargo run -p media-admin-server --features cuda",
    "server:build": "cargo build -p media-admin-server",
    "desktop:dev": "pnpm --filter @media-admin/desktop dev",
    "desktop:dev:cuda": "pnpm --filter @media-admin/desktop dev:cuda",
    "desktop:build": "pnpm --filter @media-admin/desktop build",
    "desktop:build:cuda": "pnpm --filter @media-admin/desktop build:cuda",
    "typeshare": "typeshare crates --lang=typescript --output-file=apps/web/src/types/api.ts"
  }
}
