{
  "name": "media-admin",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:server": "cargo run -p media-admin-server",
    "dev:server:cuda": "cargo run -p media-admin-server --features cuda",
    "dev:desktop": "pnpm --filter @media-admin/desktop dev",
    "build:web": "pnpm --filter web build",
    "build:server": "cargo build -p media-admin-server",
    "build:desktop": "pnpm --filter @media-admin/desktop build",
    "build:desktop:cuda": "pnpm --filter @media-admin/desktop build:cuda",
    "lint": "pnpm --filter web lint",
    "preview": "pnpm --filter web preview",
    "typeshare": "typeshare crates --lang=typescript --output-file=apps/web/src/types/api.ts"
  }
}
