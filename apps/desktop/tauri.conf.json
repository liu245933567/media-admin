{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "media-admin",
  "version": "0.1.0",
  "identifier": "com.mediaadmin.desktop",
  "build": {
    "frontendDist": "../../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm --dir ../web run dev",
    "beforeBuildCommand": "pnpm --dir ../web run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
